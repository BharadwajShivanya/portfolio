  public_key : blob;
  chain_code : blob;
};

type sign_with_ecdsa_args = record {
  message_hash : blob;
  derivation_path : vec blob;
  key_id : record { curve : ecdsa_curve; name : text };
};

type sign_with_ecdsa_result = record {
  signature : blob;
};

type schnorr_public_key_args = record {
  canister_id : opt canister_id;
  derivation_path : vec blob;
