<file path="src/frontend/src/index.css">
@import url("https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Lora:ital,wght@0,400..700;1,400..700&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap");
@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --font-display: "Fraunces";
    --font-body: "DM Sans";
    --font-mono: monospace;
    --radius: 0.75rem;

    /* Curated Luxury Warm Cream & Dusty Rose Palette */
    --background: 0.97 0.01 30;
    --foreground: 0.2 0.02 10;

    /* Card background with soft rose-parchment tint */
    --card: 0.985 0.005 28;
    --card-foreground: 0.2 0.02 10;
    --popover: 0.985 0.005 28;
    --popover-foreground: 0.2 0.02 10;

    /* Elegant Warm Dusty Rose Primary */
    --primary: 0.52 0.16 8;
    --primary-foreground: 0.97 0.01 30;

    /* Gentle Rose Accent Secondary */
    --secondary: 0.65 0.12 22;
    --secondary-foreground: 0.2 0.02 10;

    /* Cream Muted */
    --muted: 0.92 0.01 30;
    --muted-foreground: 0.5 0.02 15;

    /* Rose Highlight Accent */
    --accent: 0.52 0.16 8;
    --accent-foreground: 0.97 0.01 30;

    --destructive: 0.55 0.22 25;
    --destructive-foreground: 0.98 0 0;

    --border: 0.88 0.02 28;
    --input: 0.92 0.01 30;
    --ring: 0.52 0.16 8;

    --chart-1: 0.52 0.16 8;
    --chart-2: 0.65 0.12 22;
    --chart-3: 0.72 0.12 85;
    --chart-4: 0.58 0.18 30;
    --chart-5: 0.48 0.16 260;

    --sidebar: 0.97 0.01 30;
    --sidebar-foreground: 0.2 0.02 260;
    --sidebar-primary: 0.52 0.16 8;
    --sidebar-primary-foreground: 0.97 0.01 30;
    --sidebar-accent: 0.92 0.01 30;
    --sidebar-accent-foreground: 0.3 0.01 260;
    --sidebar-border: 0.88 0.02 28;
    --sidebar-ring: 0.52 0.16 8;
  }

  .dark {
    /* Rich soft-charcoal warm dark mode background */
    --background: 0.15 0.01 30;
    --foreground: 0.93 0.01 28;
    --card: 0.2 0.015 28;
    --card-foreground: 0.93 0.01 28;
    --popover: 0.2 0.015 28;
    --popover-foreground: 0.93 0.01 28;

    /* Softened warm rose primary for reading comfort */
    --primary: 0.72 0.12 8;
    --primary-foreground: 0.15 0.01 30;

    --secondary: 0.75 0.09 22;
    --secondary-foreground: 0.15 0.01 30;

    --muted: 0.24 0.01 30;
    --muted-foreground: 0.65 0.015 28;

    --accent: 0.72 0.12 8;
    --accent-foreground: 0.15 0.01 30;

    --destructive: 0.65 0.19 22;
    --destructive-foreground: 0.15 0.01 10;

    --border: 0.26 0.015 28;
    --input: 0.26 0.015 28;
    --ring: 0.72 0.12 8;

    --chart-1: 0.72 0.12 8;
    --chart-2: 0.68 0.14 200;
    --chart-3: 0.75 0.15 85;
    --chart-4: 0.68 0.16 30;
    --chart-5: 0.65 0.18 260;

    --sidebar: 0.15 0.01 30;
    --sidebar-foreground: 0.93 0.01 28;
    --sidebar-primary: 0.72 0.12 8;
    --sidebar-primary-foreground: 0.15 0.01 30;
    --sidebar-accent: 0.24 0.01 30;
    --sidebar-accent-foreground: 0.85 0.01 50;
    --sidebar-border: 0.26 0.015 28;
    --sidebar-ring: 0.72 0.12 8;
  }

  * {
    @apply border-border;
  }
  body {
    @apply bg-background text-foreground font-body antialiased;
  }
}

@layer utilities {
  .transition-smooth {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }

  .slide-up {
    animation: slideUp 0.5s ease-out forwards;
  }

  .letter-shadow {
    box-shadow: 0 4px 24px oklch(0.48 0.14 8 / 0.12), 0 1px 4px
      oklch(0.48 0.14 8 / 0.08);
  }

  .rose-glow {
    box-shadow: 0 0 0 3px oklch(0.48 0.14 8 / 0.15);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .parchment-texture {
    background-image: radial-gradient(
        circle at 20% 30%,
        oklch(0.72 0.08 18 / 0.08) 0%,
        transparent 60%
      ),
      radial-gradient(
        circle at 80% 70%,
        oklch(0.78 0.06 24 / 0.06) 0%,
        transparent 60%
      );
  }

  .font-display {
    font-family: var(--font-display), serif;
  }

  .font-body {
    font-family: var(--font-body), serif;
  }

  .font-script {
    font-family: var(--font-display), serif;
    font-style: italic;
  }
}

.scroll-reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.65s cubic-bezier(0.4, 0, 0.2, 1), transform 0.65s
    cubic-bezier(0.4, 0, 0.2, 1);
}

.scroll-reveal.revealed {
  opacity: 1;
  transform: translateY(0);
}
